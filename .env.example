# Required for Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Chains to monitor. Supported by this bot: solana, ethereum.
CHAINS=solana,ethereum

# Poll interval in seconds.
POLL_SECONDS=300

# Keep pairs created within this age window.
MAX_PAIR_AGE_HOURS=72

# Alert filters.
MIN_LIQUIDITY_USD=10000
MIN_VOLUME_1H_USD=5000
ALERT_SCORE_MIN=65
RUG_RISK_MAX=55
ALERT_COOLDOWN_MINUTES=180

# Use RUN_ONCE=1 for one scan, DEMO_MODE=1 to test without network.
RUN_ONCE=0
DEMO_MODE=0
